[gd_scene load_steps=4 format=3]

[ext_resource type="PackedScene" path="res://scenes/spell.tscn" id="PackedScene_scenes_spell_tscn"]
[ext_resource type="PackedScene" path="res://scenes/tile.tscn" id="PackedScene_scenes_tile_tscn"]
[ext_resource type="Script" path="res://scripts/main.gd" id="Script_scripts_main_gd"]

[node name="Main" type="Control"]
script = ExtResource("Script_scripts_main_gd")
anchors_preset = 15
offset_bottom = 420
offset_right = 560

[node name="Panel" type="Panel" parent="."]
anchors_preset = 15
offset_bottom = 400
offset_left = 20
offset_right = 540
offset_top = 20

[node name="VBox" type="VBoxContainer" parent="Panel"]
anchors_preset = 15
offset_bottom = 364
offset_left = 16
offset_right = 504
offset_top = 16

[node name="Title" type="Label" parent="Panel/VBox"]
horizontal_alignment = 1
text = "LD49 drag spell slice"
theme_override_font_sizes = {"font_size": 24}

[node name="LogLabel" type="Label" parent="Panel/VBox"]
horizontal_alignment = 1
text = "Drop a spell onto a tile"

[node name="MapGrid" type="GridContainer" parent="Panel/VBox"]
columns = 3

[node name="TileA1" parent="Panel/VBox/MapGrid" instance=ExtResource("PackedScene_scenes_tile_tscn")]
tile_id = "A1"

[node name="TileA2" parent="Panel/VBox/MapGrid" instance=ExtResource("PackedScene_scenes_tile_tscn")]
tile_id = "A2"

[node name="TileA3" parent="Panel/VBox/MapGrid" instance=ExtResource("PackedScene_scenes_tile_tscn")]
tile_id = "A3"

[node name="TileB1" parent="Panel/VBox/MapGrid" instance=ExtResource("PackedScene_scenes_tile_tscn")]
tile_id = "B1"

[node name="TileB2" parent="Panel/VBox/MapGrid" instance=ExtResource("PackedScene_scenes_tile_tscn")]
tile_id = "B2"

[node name="TileB3" parent="Panel/VBox/MapGrid" instance=ExtResource("PackedScene_scenes_tile_tscn")]
tile_id = "B3"

[node name="SpellBar" type="HBoxContainer" parent="Panel/VBox"]

[node name="SparkSpell" parent="Panel/VBox/SpellBar" instance=ExtResource("PackedScene_scenes_spell_tscn")]
display_name = "Spark"
spell_id = "spark"

[node name="FreezeSpell" parent="Panel/VBox/SpellBar" instance=ExtResource("PackedScene_scenes_spell_tscn")]
display_name = "Freeze"
spell_id = "freeze"

[node name="ShieldSpell" parent="Panel/VBox/SpellBar" instance=ExtResource("PackedScene_scenes_spell_tscn")]
display_name = "Shield"
spell_id = "shield"


